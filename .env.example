# ============================================================
# Application
# ============================================================
NODE_ENV=development
PORT=3000

# Public base URL (used for OAuth redirects, etc.)
# IMPORTANT: NEXT_PUBLIC_* vars are inlined at build time
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================================
# Database
# ============================================================
# PostgreSQL connection string
DATABASE_URL=postgresql://leadportal:password@localhost:5432/leadportal

# Used by docker-compose for the postgres service
POSTGRES_PASSWORD=password

# ============================================================
# Admin Authentication
# ============================================================
# Password for the /dashboard admin login
ADMIN_PASSWORD=changeme-in-production

# Secret key for signing JWT tokens (min 32 chars, use a random string)
JWT_SECRET=your-256-bit-secret-here-change-in-production

# Shared secret protecting the /api/cron/sync recovery job.
# Vercel Cron sends this automatically as "Authorization: Bearer <CRON_SECRET>".
# Use a long random string.
CRON_SECRET=your-random-cron-secret-here

# ============================================================
# HubSpot OAuth 2.0
# ============================================================
# Create a HubSpot developer app at https://developers.hubspot.com
# Set the redirect URI in your HubSpot app to match HUBSPOT_REDIRECT_URI below

# Set to true to use an in-memory mock of the HubSpot API — no account, OAuth,
# or token required. Leads sync end-to-end against fake contact/company IDs.
# For local development and demos ONLY. Leave empty/false in production.
HUBSPOT_MOCK=

HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=

# Must exactly match the redirect URI registered in your HubSpot app
HUBSPOT_REDIRECT_URI=http://localhost:3000/api/hubspot/callback

# Optional: set a static access token for testing without OAuth
# If set, this takes priority over the DB-stored OAuth token
HUBSPOT_ACCESS_TOKEN=
