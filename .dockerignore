.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Test and development files
coverage
__tests__
tests
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
jest.config.ts
jest.setup.ts

# Version control
.git
.gitignore

# Editor
.vscode
.idea
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Prisma generated (regenerated in Docker)
prisma/generated

# Docker files themselves
Dockerfile
docker-compose.yml
.dockerignore

# README and docs
README.md
*.md
